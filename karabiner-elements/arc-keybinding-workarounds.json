{
  "description": "Arc keybinding workarounds",
  "manipulators": [
    {
      "conditions": [
        {
          "bundle_identifiers": [
            "^company\\.thebrowser\\.Browser.*"
          ],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "k",
        "modifiers": {
          "mandatory": [
            "control"
          ],
          "optional": [
            "caps_lock",
            "shift"
          ]
        }
      },
      "to": [
        {
          "key_code": "right_arrow",
          "modifiers": [
            "left_command",
            "left_shift"
          ]
        },
        {
          "key_code": "delete_forward"
        }
      ],
      "type": "basic"
    }
  ]
}
